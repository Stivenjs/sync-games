{
  "name": "sync-games",
  "version": "1.6.5",
  "private": true,
  "bin": {
    "sync-games": "./src/cli/index.ts"
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/interfaces/http/server.ts",
    "cli": "bun src/cli/index.ts",
    "build:cli": "bun run scripts/build-cli.ts",
    "api-key": "bun run scripts/generate-api-key.ts",
    "api-key:live": "bun run scripts/generate-api-key.ts -- --live",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:live": "serverless deploy --stage live",
    "invoke:local": "serverless invoke local -f api",
    "lint": "eslint src --ext .ts",
    "desktop": "bun run --cwd apps/sync-games-desktop tauri dev",
    "desktop:dev": "bun run --cwd apps/sync-games-desktop dev",
    "desktop:build": "bun run --cwd apps/sync-games-desktop tauri build",
    "cargo:check": "bun run --cwd apps/sync-games-desktop/src-tauri cargo check",
    "cargo:clean": "bun run --cwd apps/sync-games-desktop/src-tauri cargo clean",
    "sync-version": "bun run scripts/sync-version.ts",
    "format": "bunx prettier . --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint-staged": {
      "*.{js,jsx,ts,tsx,json,css,scss,md}": [
        "bunx prettier . --write \"**/*.{js,jsx,ts,tsx,json,css,md}\""
      ]
    },
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@fastify/aws-lambda": "^4.0.0",
    "@fastify/cors": "^10.0.0",
    "@inquirer/prompts": "^8.3.0",
    "fastify": "^5.0.0",
    "figlet": "^1.10.0",
    "figures": "^6.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "serverless": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
